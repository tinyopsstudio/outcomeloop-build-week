{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary", "next_action", "evidence", "gate"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["progress", "claimed_complete", "owner_gate"]
    },
    "summary": {
      "type": "string",
      "maxLength": 1200
    },
    "next_action": {
      "type": "string",
      "maxLength": 1200
    },
    "evidence": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "source"],
        "properties": {
          "claim": { "type": "string", "maxLength": 500 },
          "source": { "type": "string", "maxLength": 500 }
        }
      }
    },
    "gate": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "reason", "owner_action"],
          "properties": {
            "type": { "type": "string", "maxLength": 80 },
            "reason": { "type": "string", "maxLength": 800 },
            "owner_action": { "type": "string", "maxLength": 800 }
          }
        },
        { "type": "null" }
      ]
    }
  }
}
