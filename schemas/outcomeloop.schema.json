{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OutcomeLoop contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "objective", "completion"],
  "properties": {
    "version": { "const": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "workspace": { "type": "string" },
    "model": { "type": "string" },
    "sandbox": { "enum": ["read-only", "workspace-write"] },
    "maxIterations": { "type": "integer", "minimum": 1, "maximum": 100 },
    "maxRuntimeMinutes": { "type": "number", "exclusiveMinimum": 0, "maximum": 1440 },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "allowedGates": { "type": "array", "items": { "type": "string" } },
    "protectedPaths": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "loadExecPolicyRules": { "type": "boolean" },
    "completion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command"],
      "properties": {
        "command": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "successExitCode": { "type": "integer" },
        "timeoutMs": { "type": "integer", "minimum": 100, "maximum": 3600000 }
      }
    }
  }
}
